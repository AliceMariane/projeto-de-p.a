from tkinter import * 
from tkinter import colorchooser
import sys
import os

# Janela principal
class Janela:

    def __init__(self, root):

        self.root = root
        self.root.title('Paint CAR')
        self.root.geometry('720x1080')

        self.cor_atual = 'black'
        self.icone()
        self.menu()

    def icone (self):
        icon = os.path.dirname(os.path.abspath(__file__))
        # aplicando o icone em quaisque OS
        try:
            if sys.platform.startswith('win'):
                caminho = os.path.join(icone,'icone_pa.ico')
                self.root.iconbitmap(caminho)
            else:
                caminho = os.path.join(icone, 'icone_png')
                img = PhotoImage(file=caminho)
                self.root.iconphoto(True, img)

        except Exception as e:
            print(f'Icone invalido: {e}')

        
    
    def menu (self):

        self.frame_menu = Frame(self.root, bg='gray', pady=20)
        self.frame_menu.pack(fill=X)

        # outros frames incluidos no menu principal

        f_cores = Frame(self.frame_menu, bg='lightgray')
        f_cores.pack(side=LEFT, padx=10)
        

        self.btao_c() # paleta de cores
        btao_paleta = Button(self.f_cores, text='Paleta', command=self.palet_c)
        btao_paleta.grind(row=0,column=10, padx=5)
       #'''' self.btao_forma() # Formas geometricas
        #self.btao_ferramentas() # Ferramentas(pinceis, borracha)'''

    def define_cores(self, nova_cor):

        self.cor_atual = nova_cor
        print(f'Cor atual: {self.cor_atual}')



    def btao_c(self):

        lst_cores = ['red', 'green', 'blue','yellow', 'orange',
                'brown', 'pink', 'black', 'white']

        for i, cor_ in  enumerate(lst_cores):
            btao = Button(
                self.f_cores,
                bg=cor_,
                width=2,
                height=1,
                command=lambda c=cor_:cor_padrao(c)
                
            )
            btao.grid(row=0, column=i, padx=2)
        
        def palet_c(self):
            
            cor =color.askcolor(title='Escolha uma cor')[1]
            
            if cor:
                cor_padrao=(cor)
                print(f'Cor escolhida: {cor}')
if __name__ == '__main__':
    root = Tk()
    app = Janela(root)
    root.mainloop()

        

