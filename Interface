import sys
import os
import tkinter as tk
import tkinter.colorchooser as colorchooser

# janela principal 
janela = tk.Tk()

# pasta do script, caminho relativo para o icone

pasta_projeto: str = os.path.dirname(os.path.abspath(__file__))

try:
    if sys.platform.startswith('win'):
        caminho = os.path.join(pasta_projeto, "icon_pa.ico")
        janela.iconbitmap(caminho)
    else:
        caminho = os.path.join(pasta_projeto, "icon_pa.png")
        icone = tk.PhotoImage(file=caminho)
        janela.iconphoto(True, icone)
except Exception as e:
    print(f"icone não encontrado: {e}")

janela.title("Paint CAR")
janela.geometry("1920x1080")

# frame dos menus
frame_menu = tk.Frame(janela, bg="gray", pady=25)
frame_menu.pack(fill=tk.X)


# paleta de cores
def selct_cor():
    cor_escolhida = colorchooser.askcolor(title="Escolha uma cor")[1]

    if cor_escolhida:
        print(f'Cor escolhida: {cor_escolhida}')


def cor_padrao(cor_selecionada):
    print(f'Cor padrão:{cor_selecionada}')


def limpar_tela():
    print("Tela limpa")


# subframe cores
frame_cores = tk.Frame(frame_menu, bg="lightgray")
frame_cores.pack(side=tk.LEFT, padx=10)

cores = ["red", "green", "blue", "yellow", "orange",
          "brown", "pink", "black", "white"]

for i, cor in enumerate(cores):
    btao = tk.Button(
        frame_cores,
        bg=cor,
        width=2,
        height=1,
        command=lambda c=cor: cor_padrao(c)
    )
    btao.grid(row=0, column=i, padx=2)

botao_paleta = tk.Button(frame_menu, text="Paleta de cores", command=selct_cor)
botao_paleta.pack(side=tk.LEFT, padx=10)
# botao escolher cor

# botao limpar tela
botao_limpar = tk.Button(frame_menu, text="Limpar tela", command=limpar_tela)
botao_limpar.pack(side=tk.LEFT, padx=10)

janela.mainloop()
